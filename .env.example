DEBUG=1
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
# En produccion (DEBUG=0), agregar el dominio real, ej:
# ALLOWED_HOSTS=trivia.midominio.com
# CSRF_TRUSTED_ORIGINS=https://trivia.midominio.com

POSTGRES_DB=triviamillon
POSTGRES_USER=triviamillon
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
# Si tu Redis de produccion pide contrasena (lo normal en un servicio gestionado
# como el de Dokploy), agregala aqui:
# REDIS_PASSWORD=change-me
# O bien, si el proveedor te da la URL completa (redis://:password@host:puerto/0),
# usa esta en vez de las tres de arriba (tiene prioridad si esta presente):
# REDIS_URL=redis://:change-me@redis-host:6379/0

# Opcional: si estan las tres, el contenedor crea este superusuario solo al
# arrancar (una sola vez; si ya existe un usuario con ese username no hace nada).
# Util en produccion (Dokploy), donde no hay una terminal para correr
# createsuperuser a mano. Configuralas en el panel de variables de entorno del
# servicio, nunca las dejes con estos valores de ejemplo.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me
